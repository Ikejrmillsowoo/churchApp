# Copy this file to .env.local and fill in the values. NEVER commit .env.local.
# Find these in your Supabase project dashboard under Settings > API.

# Project URL (safe to expose to the browser).
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (safe to expose to the browser; RLS protects your data).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY. Bypasses Row Level Security. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
